{
	email contact@bg2s.com
}

www.bg2s.com {
	redir https://bg2s.com{uri} permanent
}

bg2s.com {
	root * /srv
	encode zstd gzip
	file_server

	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		Cross-Origin-Embedder-Policy "unsafe-none"
		Cross-Origin-Opener-Policy "same-origin-allow-popups"
		Cross-Origin-Resource-Policy "cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' https://umami.nizart.me; connect-src 'self' https://umami.nizart.me; img-src 'self' data: https://umami.nizart.me; style-src 'self' 'unsafe-inline'; font-src 'self'; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self';"
		-Server
	}

	@assets path_regexp \.(css|js|woff2?|eot|ttf|otf|svg|ico|jpg|jpeg|gif|png|webp|mp4|webm|avif)$
	header @assets Cache-Control "public, max-age=15552000, immutable"
}
