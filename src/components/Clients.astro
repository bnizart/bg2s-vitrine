---
const logos = import.meta.glob("../assets/images/clients/*.{png,jpg,jpeg}", {
    eager: true,
});
---

<section id="services" class="bg-gray-50 py-20 px-6">
    <div class="max-w-7xl mx-auto text-center">
        <h2 class="text-4xl font-extrabold text-gray-900 mb-4">
            Ils nous font confiance
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto mb-12 text-xl">
            Pourquoi pas vous ?
        </p>

        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 items-center justify-items-center"
        >
            {
                Object.entries(logos).map(([path, mod]) => {
                    const fileName = path.split("/").pop().split(".")[0];
                    const imageUrl = mod.default.src;
                    return (
                        <img
                            src={imageUrl}
                            alt={fileName}
                            class="h-20 object-contain"
                            loading="lazy"
                        />
                    );
                })
            }
        </div>
    </div>
</section>
