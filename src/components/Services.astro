---
import { Icon } from "astro-icon/components";
---

<section id="services" class="bg-gray-50 py-20 px-6">
    <div class="max-w-7xl mx-auto text-center">
        <h2 class="text-4xl font-extrabold text-gray-900 mb-4">Nos Services</h2>
        <p class="text-gray-600 max-w-2xl mx-auto mb-12 text-xl">
            Gardiennage, ronde, télésurveillance, intervention sur alarme et
            installation de système de sécurité
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div
                class="overflow-hidden text-center bg-white rounded shadow-md text-slate-500 shadow-slate-200"
            >
                <!-- Icon -->
                <div class="text-red-600 w-18 h-18 m-auto mt-3">
                    <Icon name="mdi:account-supervisor" class="w-full h-full" />
                </div>
                <!-- Body-->
                <div class="p-6">
                    <h3 class="mb-4 text-xl font-medium text-slate-700">
                        Gardiennage
                    </h3>
                    <p>
                        Service de gardiennage professionnel pour sécuriser vos
                        locaux 24h/24.
                    </p>
                </div>
            </div>

            <div
                class="overflow-hidden text-center bg-white rounded shadow-md text-slate-500 shadow-slate-200"
            >
                <!-- Icon -->
                <div class="text-red-600 w-18 h-18 m-auto mt-3">
                    <Icon name="mdi:eye-settings" class="w-full h-full" />
                </div>
                <!-- Body-->
                <div class="p-6">
                    <h3 class="mb-4 text-xl font-medium text-slate-700">
                        Télésurveillance
                    </h3>
                    <p>
                        Surveillance à distance avec intervention rapide en cas
                        d'alerte.
                    </p>
                </div>
            </div>

            <div
                class="overflow-hidden text-center bg-white rounded shadow-md text-slate-500 shadow-slate-200"
            >
                <!-- Icon -->
                <div class="text-red-600 w-18 h-18 m-auto mt-3">
                    <Icon name="mdi:shield-outline" class="w-full h-full" />
                </div>
                <!-- Body-->
                <div class="p-6">
                    <h3 class="mb-4 text-xl font-medium text-slate-700">
                        Ronde de Sécurité
                    </h3>
                    <p>
                        Rondes de surveillance programmées pour vos sites
                        sensibles.
                    </p>
                </div>
            </div>

            <div
                class="overflow-hidden text-center bg-white rounded shadow-md text-slate-500 shadow-slate-200"
            >
                <!-- Icon -->
                <div class="text-red-600 w-18 h-18 m-auto mt-3">
                    <Icon name="mdi:tools" class="w-full h-full" />
                </div>
                <!-- Body-->
                <div class="p-6">
                    <h3 class="mb-4 text-xl font-medium text-slate-700">
                        Installation
                    </h3>
                    <p>
                        Installation et maintenance de systèmes de sécurité sur
                        mesure.
                    </p>
                </div>
            </div>            
        </div>
    </div>
</section>
